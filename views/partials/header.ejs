<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Grocery Store MVC</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🛒</text></svg>">
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar">
  <div class="navbar-inner">
    <a href="/" class="navbar-brand">
      <span class="emoji">🛒</span> Grocery Store
    </a>
    <ul class="navbar-nav">
      <li><a href="/" class="nav-link">🏠 Home</a></li>
      <li><a href="/products" class="nav-link">🥦 Produk</a></li>
      <li>
        <a href="/cart" class="nav-link">
          🛒 Keranjang
          <% if (cartId) { %><span class="nav-badge">✓</span><% } %>
        </a>
      </li>
      <li>
        <a href="/orders" class="nav-link">
          📦 Pesanan
        </a>
      </li>
      <li>
        <a href="/auth" class="nav-link">
          🔑 Auth
          <% if (accessToken) { %><span class="nav-badge token">Token ✓</span><% } %>
        </a>
      </li>
    </ul>
  </div>
</nav>

<main class="main-content">

  <!-- Flash Messages -->
  <% if (successMsg && successMsg.length > 0) { %>
    <div class="alert alert-success">✅ <%= successMsg %></div>
  <% } %>
  <% if (errorMsg && errorMsg.length > 0) { %>
    <div class="alert alert-error">❌ <%= errorMsg %></div>
  <% } %>
