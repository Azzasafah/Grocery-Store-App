<%- include('../../partials/header') %>

<div class="page-header">
  <a href="/orders" class="btn btn-secondary btn-sm" style="margin-bottom:1rem;">← Kembali ke Pesanan</a>
  <h1>📦 Buat Pesanan Baru</h1>
  <p>Checkout keranjang belanjamu menjadi pesanan</p>
</div>

<div class="info-box">
  <p>Endpoint: <code>POST /orders</code></p>
  <p>Body: <code>{"cartId": "...", "customerName": "..."}</code></p>
  <p>Header wajib: <code>Authorization: Bearer &lt;token&gt;</code></p>
</div>

<div style="max-width: 560px;">
  <div class="card">
    <div class="card-header">
      <h3>📋 Form Pesanan</h3>
    </div>
    <div class="card-body">
      <form method="POST" action="/orders">
        <div class="form-group">
          <label class="form-label">Cart ID</label>
          <input type="text" name="cartId" class="form-control"
            value="<%= cartId || '' %>"
            placeholder="Masukkan Cart ID" required>
          <div class="form-hint">
            <% if (cartId) { %>
              ✅ Cart ID aktif dari session: <strong><%= cartId %></strong>
            <% } else { %>
              ⚠️ Belum ada cart. <a href="/cart">Buat keranjang dulu</a>, lalu tambah produk.
            <% } %>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Nama Customer</label>
          <input type="text" name="customerName" class="form-control"
            placeholder="Contoh: Budi Santoso" required>
          <div class="form-hint">Nama penerima pesanan</div>
        </div>
        <button type="submit" class="btn btn-primary btn-block btn-lg">
          📦 Buat Pesanan Sekarang
        </button>
      </form>
    </div>
  </div>

  <!-- Checklist -->
  <div class="card" style="margin-top:1.5rem;">
    <div class="card-header"><h3>✅ Checklist Sebelum Order</h3></div>
    <div class="card-body">
      <ul style="list-style:none; line-height:2.2; font-size:0.9rem;">
        <li>
          <% if (accessToken) { %> ✅ <% } else { %> ❌ <% } %>
          Access Token tersimpan
          <% if (!accessToken) { %> — <a href="/auth">Daftar sekarang</a><% } %>
        </li>
        <li>
          <% if (cartId) { %> ✅ <% } else { %> ❌ <% } %>
          Punya Cart ID aktif
          <% if (!cartId) { %> — <a href="/cart">Buat keranjang</a><% } %>
        </li>
        <li>🟡 Cart sudah berisi produk (cek di <a href="/cart">halaman keranjang</a>)</li>
      </ul>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
